# Copy this file to .env.local and fill in your values

# Supabase - get from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Password that all lab members will use to log in
SITE_PASSWORD=your-lab-password-here

# Random secret string (just type any random characters)
AUTH_SECRET=change-this-to-something-random-like-abc123xyz
